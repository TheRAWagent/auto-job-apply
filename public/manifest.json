{
  "manifest_version": 3,
  "name": "Auto Job Apply",
  "version": "0.0.1",
  "description": "Automatically apply to job listings",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "logo-16.png",
      "32": "logo-32.png",
      "48": "logo-48.png",
      "128": "logo-128.png"
    }
    
  }

}
